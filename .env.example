# Hosted Postgres (Neon / Supabase / Railway…) — use the POOLED connection string.
# Leave unset for local dev: the app falls back to embedded PGlite in ./.data/pglite.
# DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# Authentication methods. Email/password is fail-closed: only "true" enables it.
AUTH_EMAIL_PASSWORD_ENABLED=false
NEXT_PUBLIC_APP_URL="https://macroverse.vercel.app"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend transactional email (required before re-enabling email/password in production)
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="MacroVerse <accounts@your-verified-domain.com>"
# RESEND_REPLY_TO="support@your-verified-domain.com"
# Public only after a signed MacroTray GitHub Release has been verified.
NEXT_PUBLIC_MACROTRAY_DOWNLOAD_URL=
