{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MacroTray",
  "version": "0.1.0",
  "identifier": "com.macroverse.macrotray",
  "build": {
    "frontendDist": "placeholder"
  },
  "app": {
    "windows": [],
    "security": {
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["../public/icon-512.png"],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/zja1999/Macro-Map-3.0/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
